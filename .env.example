# ========== 复制本文件为 .env 后按需修改 ==========
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

# Flask
SECRET_KEY=请替换为随机长字符串
FLASK_DEBUG=false
WEB_HOST=0.0.0.0
WEB_PORT=5000

# 会话 Cookie 持久化时间（秒，默认 86400=24h）
PERMANENT_SESSION_LIFETIME_SEC=86400

# 默认 Shell 监听端口（界面默认值）
DEFAULT_SHELL_PORT=4444

# Socket.IO CORS，生产环境建议改为具体域名
SOCKETIO_CORS_ORIGINS=*

# ---------- 认证（首次 init_db 会写入数据库；无库时登录也校验此组）----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请修改为强密码

# ---------- 数据库（二选一）----------
# 方式 A：完整 URL（可 SQLite 可 MySQL）
# DATABASE_URL=sqlite:///C:/path/to/instance/shell_manager.db
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/dbname?charset=utf8mb4

# 方式 B：MySQL 分项（未设置 DATABASE_URL 且下列齐全则自动拼接）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=shellmgr
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=shellmgr

# 若既无 DATABASE_URL 也未配全 MySQL，将自动使用项目下 instance/shell_manager.db（SQLite）

# SQLAlchemy 调试
SQLALCHEMY_ECHO=false
SQLALCHEMY_TRACK_MODIFICATIONS=false
